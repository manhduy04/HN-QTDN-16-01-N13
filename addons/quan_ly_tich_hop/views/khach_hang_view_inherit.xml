<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_khach_hang_form_inherit_cong_viec"
            model="ir.ui.view">

        <field name="name">
            khach_hang.form.inherit.cong_viec
        </field>

        <field name="model">khach_hang</field>

        <field name="inherit_id"
               ref="quan_ly_khach_hang.view_khach_hang_form"/>

        <field name="arch" type="xml">

            <notebook position="inside">

                <page string="Công việc">

                    <field name="cong_viec_ids">

                        <tree editable="bottom">
                            <field name="name"/>
                            <field name="nhan_vien_id"/>
                            <field name="ngay_bat_dau"/>
                            <field name="ngay_ket_thuc"/>
                            <field name="trang_thai"/>
                            <field name="tien_do" widget="progressbar"/>
                        </tree>

                    </field>

                </page>

            </notebook>

        </field>

    </record>

</odoo>