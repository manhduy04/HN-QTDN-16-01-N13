<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_khach_hang_form_inherit" model="ir.ui.view">

        <field name="name">khach_hang.form.inherit</field>

        <field name="model">khach_hang</field>

        <field name="inherit_id"
               ref="quan_ly_khach_hang.view_khach_hang_form"/>

        <field name="arch" type="xml">

            <xpath expr="//sheet" position="inside">

                <notebook>

                    <page string="Công việc">

                        <label string="Đã kết nối thành công."/>

                    </page>

                </notebook>

            </xpath>

        </field>

    </record>

</odoo>