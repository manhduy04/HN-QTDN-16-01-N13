<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- TREE -->
        <record id="view_cong_viec_tree" model="ir.ui.view">
            <field name="name">cong_viec.tree</field>
            <field name="model">cong_viec.cong_viec</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="khach_hang_id"/>
                    <field name="nhan_vien_id"/>
                    <field name="ngay_bat_dau"/>
                    <field name="ngay_ket_thuc"/>
                    <field name="trang_thai"/>
                </tree>
            </field>
        </record>

        <!-- FORM -->
        <record id="view_cong_viec_form" model="ir.ui.view">
            <field name="name">cong_viec.form</field>
            <field name="model">cong_viec.cong_viec</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="khach_hang_id"/>
                            <field name="nhan_vien_id"/>
                            <field name="trang_thai"/>
                        </group>
                        <group>
                            <field name="ngay_bat_dau"/>
                            <field name="ngay_ket_thuc"/>
                        </group>
                        <group>
                            <field name="mo_ta"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ACTION -->
        <record id="action_cong_viec" model="ir.actions.act_window">
            <field name="name">Quản lý công việc</field>
            <field name="res_model">cong_viec.cong_viec</field>
            <field name="view_mode">tree,form</field>
        </record>

    </data>
</odoo>
