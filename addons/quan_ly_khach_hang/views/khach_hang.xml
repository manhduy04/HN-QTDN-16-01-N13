<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- TREE -->
        <record id="view_khach_hang_tree" model="ir.ui.view">
            <field name="model">khach_hang</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="ma_khach_hang"/>
                    <field name="ten_khach_hang"/>
                    
                    <field name="loai_khach_hang"/>
                    <field name="so_dien_thoai"/>
                    <field name="email"/>
                </tree>
            </field>
        </record>

        <!-- FORM -->
        <record id="view_khach_hang_form" model="ir.ui.view">
            <field name="model">khach_hang</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <header>

                            <button
                                name="action_tom_tat_ai"
                                string="Tóm tắt bằng AI"
                                type="object"
                                class="oe_highlight"/>

                            <button
                                name="action_goi_y_cham_soc"
                                type="object"
                                string="Gợi ý chăm sóc"/>

                            <button
                                name="action_soan_email"
                                string="Soạn email bằng AI"
                                type="object"/>

                        </header>
                        <group>
                            <field name="ma_khach_hang"/>
                            <field name="ten_khach_hang"/>
                            <field name="nhan_vien_phu_trach_id"/>
                            <field name="loai_khach_hang"/>
                            <field name="email"/>
                            <field name="so_dien_thoai"/>
                            <field name="dia_chi"/>
                            <field name="ngay_dang_ky"/>
                            <field name="ghi_chu"/>
                            <field name="trang_thai_cham_soc"/>

                            <separator string="AI"/>

                            <field
                                name="tom_tat_ai"
                                readonly="1"/>

                            <field
                                name="goi_y_cham_soc"
                                readonly="1"/>

                            <field
                                name="email_ai"
                                readonly="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ACTION -->
        <record id="action_khach_hang" model="ir.actions.act_window">
            <field name="name">Khách hàng</field>
            <field name="res_model">khach_hang</field>
            <field name="view_mode">tree,form</field>
        </record>

    </data>
</odoo>
